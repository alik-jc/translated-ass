Dialogue: 0,0:09:00.00,0:15:00.00,Haniyae - Center,,40,40,0,,aniyae.net
Dialogue: 0,0:18:00.00,0:22:00.00,Haniyae - Izquierda,,40,40,0,,aniyae.net
Dialogue: 0,0:00:58.60,0:00:59.52,Default,Anna,0,0,0,,¿Quién es?
Dialogue: 0,0:00:59.64,0:01:01.39,Default,Roland,0,0,0,,Soy yo, Anna.
Dialogue: 0,0:01:02.27,0:01:04.06,Default,Roland,0,0,0,,Perdona mi visita tan tarde,
Dialogue: 0,0:01:04.60,0:01:07.39,Default,Roland,0,0,0,,pero debo hablar contigo\Ncon urgencia.
Dialogue: 0,0:01:20.06,0:01:21.35,Default,Anna,0,0,0,,¿Alteza?
Dialogue: 0,0:03:31.43,0:03:33.18,Default,Rossignol,0,0,0,,No temas, Alteza.
Dialogue: 0,0:03:33.47,0:03:34.72,Default,Anna,0,0,0,,No corres peligro.
Dialogue: 0,0:03:35.52,0:03:36.56,Default,Roland,0,0,0,,¿Quién…?
Dialogue: 0,0:03:37.14,0:03:38.22,Default,Roland,0,0,0,,¿Quién eres?
Dialogue: 0,0:03:40.52,0:03:42.35,Default,Roland,0,0,0,,\¿El Ojo del Diablo del Monte Sagrado?
Dialogue: 0,0:03:44.14,0:03:48.35,Default,Rossignol,0,0,0,,No creí\Nque Su Alteza fuera tan culta.
Dialogue: 0,0:03:53.93,0:03:55.06,Default,Roland,0,0,0,,¿Una bruja?
Dialogue: 0,0:03:56.02,0:03:59.60,Default,Rossignol,0,0,0,,En efecto.\NPuedes llamarme «Rossignol».
Dialogue: 0,0:03:59.72,0:04:00.93,Default,Roland,0,0,0,,¿Rossignol?
Dialogue: 0,0:04:01.72,0:04:03.43,Default,Roland,0,0,0,,¿Qué vienes a hacer aquí?
Dialogue: 0,0:04:04.14,0:04:06.68,Default,Rossignol,0,0,0,,Primero,\Nquiero agradecerte,
Dialogue: 0,0:04:06.89,0:04:08.52,Default,Roland,0,0,0,,Su Alteza.
Dialogue: 0,0:04:08.85,0:04:11.06,Default,Roland,0,0,0,,¿Agradecerme? ¿Por qué?
Dialogue: 0,0:04:11.64,0:04:13.39,Default,Rossignol,0,0,0,,Salvaste a Anna y a Nana.
Dialogue: 0,0:04:14.22,0:04:16.10,Default,Roland,0,0,0,,¿Las conoces?
Dialogue: 0,0:04:16.27,0:04:19.72,Default,Rossignol,0,0,0,,Vine a rescatar a la bruja\Nque había sido arrestada.
Dialogue: 0,0:04:19.89,0:04:23.31,Default,Roland,0,0,0,,Pero contra todo pronóstico,\Nno la ejecutaste.
Dialogue: 0,0:04:23.43,0:04:27.31,Default,Roland,0,0,0,,Me enteré de Nana\Nobservándote esta semana.
Dialogue: 0,0:04:27.47,0:04:30.02,Default,Roland,0,0,0,,No sé por qué\Nlas perdonaste,
Dialogue: 0,0:04:30.14,0:04:33.06,Default,Roland,0,0,0,,pero te lo agradezco\\ Nen nombre de la Sociedad.
Dialogue: 0,0:04:33.47,0:04:36.85,Default,Roland,0,0,0,,¿Me seguiste\N toda la semana?
Dialogue: 0,0:04:37.18,0:04:41.06,Default,Rossignol,0,0,0,,Tengo las piernas destrozadas…\N¿No me invitas a sentarme?
Dialogue: 0,0:04:56.22,0:04:58.72,Default,Roland,0,0,0,,¿Qué pasa, te asusto?
Dialogue: 0,0:05:08.14,0:05:09.68,Default,Roland,0,0,0,,¿Puedo tener mi respuesta?
Dialogue: 0,0:05:11.68,0:05:13.39,Default,Rossignol,0,0,0,,Eres muy valiente.
Dialogue: 0,0:05:15.06,0:05:19.06,Default,Roland,0,0,0,,Normalmente veo miedo\Nen los ojos de mis interlocutores.
Dialogue: 0,0:05:19.72,0:05:22.68,Default,Rossignol,0,0,0,,Pero en los tuyos,\Nsolo hay curiosidad.
Dialogue: 0,0:05:24.18,0:05:26.14,Default,Rossignol,0,0,0,,Sí, te sigo a la pista
Dialogue: 0,0:05:26.64,0:05:28.72,Default,Rossignol,0,0,0,,desde la semana pasada.
Dialogue: 0,0:05:29.27,0:05:31.68,Default,Rossignol,0,0,0,,Observé\Ntodos tus movimientos.
Dialogue: 0,0:05:32.10,0:05:35.68,Default,Roland,0,0,0,,Pero entonces, ¿por qué salir de las sombras\N ahora?
Dialogue: 0,0:05:37.43,0:05:41.68,Default,Rossignol,0,0,0,,Tu sirvienta acaba de servirte\Nun vaso de vino.
Dialogue: 0,0:05:42.31,0:05:45.56,Default,Rossignol,0,0,0,,Pero le añadió\Nalgo especial.
Dialogue: 0,0:05:47.06,0:05:47.93,Default,Roland,0,0,0,,Tú…
Dialogue: 0,0:05:48.52,0:05:49.85,Default,Roland,0,0,0,,¿Hablas de Tyre?
Dialogue: 0,0:05:50.56,0:05:52.18,Default,Roland,0,0,0,,¿Quiso envenenarme?
Dialogue: 0,0:05:54.14,0:05:57.18,Default,Rossignol,0,0,0,,Deberías desconfiar\Nde tus amantes.
Dialogue: 0,0:05:59.93,0:06:01.35,Default,Roland,0,0,0,,Nunca la toqué.
Dialogue: 0,0:06:06.14,0:06:08.60,Default,Roland,0,0,0,,Entonces,\N¿acabás de salvarme la vida?
Dialogue: 0,0:06:09.35,0:06:10.85,Default,Roland,0,0,0,,Te lo agradezco.
Dialogue: 0,0:06:12.64,0:06:13.77,Default,Rossignol,0,0,0,,No es nada.
Dialogue: 0,0:06:14.68,0:06:19.18,Default,Rossignol,0,0,0,,Te lo debía,\Npor haber perdonado a Anna.
Dialogue: 0,0:06:19.43,0:06:22.18,Default,Rossignol,0,0,0,,Estamos en paz, ahora.
Dialogue: 0,0:06:28.02,0:06:30.18,Default,Rossignol,0,0,0,,Esta noche,\NAnna y Nana se van conmigo.
Dialogue: 0,0:06:31.31,0:06:33.18,TiretsDefault,Roland/Rossignol,220,0,0,,– ¿Las llevas?\N– Sí.
Dialogue: 0,0:06:33.47,0:06:34.39,Default,Roland,0,0,0,,¿A dónde?
Dialogue: 0,0:06:34.72,0:06:37.89,Default,Rossignol,0,0,0,,A la Sociedad de Brujas,\Ndonde es su lugar.
Dialogue: 0,0:06:38.02,0:06:38.97,Default,Roland,0,0,0,,¿Por qué?
Dialogue: 0,0:06:39.97,0:06:44.85,Default,Rossignol,0,0,0,,Allí, las brujas no son\Nni discriminadas ni perseguidas.
Dialogue: 0,0:06:45.47,0:06:47.22,Default,Roland,0,0,0,,Pueden ser ellas mismas.
Dialogue: 0,0:06:47.39,0:06:49.35,Default,Roland,0,0,0,,¡Aquí también pueden!
Dialogue: 0,0:06:49.43,0:06:53.77,Default,Roland,0,0,0,,Firmaron un contrato justo\Ny reciben buenos salarios.
Dialogue: 0,0:06:53.93,0:06:55.77,Default,Rossignol,0,0,0,,Eso te honra.
Dialogue: 0,0:06:56.35,0:06:58.77,Default,Rossignol,0,0,0,,Pero hay algo\Nque está fuera de tu alcance.
Dialogue: 0,0:06:58.97,0:07:00.81,Default,Rossignol,0,0,0,,No puedes llevarlas
Dialogue: 0,0:07:01.39,0:07:02.77,Default,Rossignol,0,0,0,,al Monte Sagrado.
Dialogue: 0,0:07:03.35,0:07:05.02,TiretsDefault,Roland/Rossignol,241,0,0,,– ¿Al Monte Sagrado?\N– Sí.
Dialogue: 0,0:07:05.85,0:07:08.89,Default,Rossignol,0,0,0,,Donde las brujas\Npueden hallar el reposo eterno.
Dialogue: 0,0:07:09.22,0:07:12.72,Default,Roland,0,0,0,,Sabemos que brujas han vivido\Nen las montañas del Norte.
Dialogue: 0,0:07:13.18,0:07:15.93,Default,Roland,0,0,0,,¿Buscas tu salvación\Nel Monte de la Desesperación?
Dialogue: 0,0:07:16.22,0:07:17.27,Default,Rossignol,0,0,0,,Qué más da.
Dialogue: 0,0:07:20.68,0:07:23.81,Default,Roland,0,0,0,,Si es así,\Nme niego a que las lleves.
Dialogue: 0,0:07:24.27,0:07:26.18,Default,Roland,0,0,0,,El invierno empieza en dos meses.
Dialogue: 0,0:07:26.39,0:07:29.35,Default,Roland,0,0,0,,Las montañas estarán plagadas\Nde bestias demoníacas.
Dialogue: 0,0:07:29.77,0:07:32.22,Default,Roland,0,0,0,,Me niego\Na entregarlas como carnada.
Dialogue: 0,0:07:33.10,0:07:36.06,Default,Roland,0,0,0,,Tu búsqueda del Monte Sagrado\Npuede esperar.
Dialogue: 0,0:07:36.18,0:07:38.31,Default,Roland,0,0,0,,Vengan a pasar el invierno aquí.
Dialogue: 0,0:07:38.89,0:07:40.97,Default,Roland,0,0,0,,Reanuden sus búsquedas\Ndespués.
Dialogue: 0,0:07:41.43,0:07:46.35,Default,Rossignol,0,0,0,,Pero… ¿me pides\Nque traiga aquí a la Sociedad?
Dialogue: 0,0:07:47.22,0:07:49.85,Default,Rossignol,0,0,0,,Es una idea original,\Npero imposible.
Dialogue: 0,0:07:50.27,0:07:54.35,Default,Rossignol,0,0,0,,Tú no temes a las brujas,\Npero no es lo usual.
Dialogue: 0,0:07:54.72,0:07:57.81,Default,Rossignol,0,0,0,,Si se enteran de nuestra presencia,\Nla Iglesia intervendrá.
Dialogue: 0,0:07:58.27,0:08:01.43,Default,Rossignol,0,0,0,,¿Por qué correr ese riesgo\Nen vez de entregármelas?
Dialogue: 0,0:08:01.68,0:08:04.68,Default,Roland,0,0,0,,Porque son importantes\Npara mí.
Dialogue: 0,0:08:05.14,0:08:06.43,Default,Rossignol,0,0,0,,En ese caso,
Dialogue: 0,0:08:06.97,0:08:09.77,Default,Rossignol,0,0,0,,salva a Anna del tormento\Nque le espera.
Dialogue: 0,0:08:10.89,0:08:13.06,Default,Roland,0,0,0,,¿Su vida está en peligro, según tú?
Dialogue: 0,0:08:13.22,0:08:16.35,Default,Rossignol,0,0,0,,Sí, por eso\Ndebe venir conmigo.
Dialogue: 0,0:08:16.77,0:08:18.43,Default,Rossignol,0,0,0,,Pronto alcanzará la edad.
Dialogue: 0,0:08:18.68,0:08:22.02,Default,Rossignol,0,0,0,,El paso a la adultez\Nes nuestro primer suplicio.
Dialogue: 0,0:08:22.35,0:08:25.02,Default,Rossignol,0,0,0,,La mayoría de las brujas\Nse despiertan en invierno,
Dialogue: 0,0:08:25.22,0:08:27.72,Default,Rossignol,0,0,0,,con la apertura\Nde la puerta del Infierno.
Dialogue: 0,0:08:27.85,0:08:30.39,Default,Rossignol,0,0,0,,El paso a la adultez\Nes un umbral clave.
Dialogue: 0,0:08:30.52,0:08:32.56,Default,Rossignol,0,0,0,,Si no tiene poderes\Na los 18 años,
Dialogue: 0,0:08:32.68,0:08:36.27,Default,Rossignol,0,0,0,,una mujer nunca despertará\Na la brujería.
Dialogue: 0,0:08:36.39,0:08:40.35,Default,Rossignol,0,0,0,,En el aniversario de nuestro despertar,\Nel Demonio toma posesión de nuestro cuerpo.
Dialogue: 0,0:08:40.77,0:08:43.93,Default,Rossignol,0,0,0,,Nos tortura haciendo hinchar\Nnuestros músculos y venas,
Dialogue: 0,0:08:44.56,0:08:49.52,Default,Rossignol,0,0,0,,hasta que sudamos sangre\Npor todos los poros, con los ojos desorbitados.
Dialogue: 0,0:08:49.64,0:08:53.56,Default,Rossignol,0,0,0,,Las más resistentes se recuperan\Nen cuatro o cinco días.
Dialogue: 0,0:08:53.77,0:08:57.18,Default,Rossignol,0,0,0,,Pero las otras,\Nsufren un martirio carajo
Dialogue: 0,0:08:57.31,0:08:59.31,Default,Rossignol,0,0,0,,hasta conocer un final atroz.
Dialogue: 0,0:08:59.77,0:09:03.02,Default,Rossignol,0,0,0,,Sus entrañas salen\Npor todos sus orificios
Dialogue: 0,0:09:03.14,0:09:05.81,Default,Rossignol,0,0,0,,y se disipan en humo negro.
Dialogue: 0,0:09:05.93,0:09:08.97,Default,Rossignol,0,0,0,,Y cuando por fin\Nno queda nada por expulsar,
Dialogue: 0,0:09:09.22,0:09:12.72,Default,Rossignol,0,0,0,,su cuerpo se rompe\Nen pedazos de carne carbonizada.
Dialogue: 0,0:09:13.39,0:09:16.10,Default,Rossignol,0,0,0,,Muchas brujas mueren\Nese día.
Dialogue: 0,0:09:17.31,0:09:20.52,Default,Rossignol,0,0,0,,Por eso nos ven\Ncomo el Mal encarnado.
Dialogue: 0,0:09:21.47,0:09:24.52,Default,Rossignol,0,0,0,,Y Anna está a punto\Nde hacerse adulta.
Dialogue: 0,0:09:25.27,0:09:29.68,Default,Rossignol,0,0,0,,La Sociedad sabrá ayudarla\Na superar esta prueba.
Dialogue: 0,0:09:29.93,0:09:32.85,Default,Rossignol,0,0,0,,Y en el Monte Sagrado,\Nconocerá la paz eterna.
Dialogue: 0,0:09:33.81,0:09:36.56,Default,Rossignol,0,0,0,,Por eso Anna y Nana\Ndeben venir conmigo.
Dialogue: 0,0:09:37.10,0:09:40.43,Default,Rossignol,0,0,0,,Quizá les sean útiles\Npara tus ambiciones,
Dialogue: 0,0:09:40.52,0:09:44.06,Default,Rossignol,0,0,0,,pero espero que les des\Nuna chance de sobrevivir.
Dialogue: 0,0:09:48.81,0:09:49.93,Default,Roland,0,0,0,,De acuerdo.
Dialogue: 0,0:09:50.43,0:09:54.81,Default,Roland,0,0,0,,Dado el riesgo, es lógico\Nque te las lleves.
Dialogue: 0,0:09:56.77,0:09:58.10,Default,Rossignol,0,0,0,,Gracias infinitas.
Dialogue: 0,0:10:00.47,0:10:02.31,Default,Roland,0,0,0,,Sabía que lo entenderías.
Dialogue: 0,0:10:47.77,0:10:48.81,Default,Anna,0,0,0,,¿Quién es?
Dialogue: 0,0:10:49.02,0:10:51.31,Default,Roland,0,0,0,,Soy yo, Anna.
Dialogue: 0,0:10:52.31,0:10:53.89,Default,Roland,0,0,0,,Perdona mi visita tan tarde,
Dialogue: 0,0:10:54.18,0:10:56.81,Default,Roland,0,0,0,,pero debo hablar contigo\Ncon urgencia.
Dialogue: 0,0:11:04.14,0:11:05.39,Default,Anna,0,0,0,,¿Alteza?
Dialogue: 0,0:11:06.47,0:11:09.14,Default,Anna,0,0,0,,Entiendo bien los riesgos,\NRossignol.
Dialogue: 0,0:11:09.85,0:11:11.43,Default,Anna,0,0,0,,Gracias por venir por mí.
Dialogue: 0,0:11:12.06,0:11:14.60,Default,Anna,0,0,0,,Pero no iré a ningún lado.
Dialogue: 0,0:11:17.43,0:11:19.14,Default,Rossignol,0,0,0,,¿Qué? ¿Pero por qué?
Dialogue: 0,0:11:19.39,0:11:21.14,Default,Anna,0,0,0,,Me quedo aquí.
Dialogue: 0,0:11:21.47,0:11:24.85,Default,Rossignol,0,0,0,,Anna, no entiendes\Nel horror de la posesión.
Dialogue: 0,0:11:25.39,0:11:29.27,Default,Rossignol,0,0,0,,Tu magia está casi madura.\NCon los meses demoníacos, tú…
Dialogue: 0,0:11:29.43,0:11:33.27,Default,Anna,0,0,0,,Qué importa.\NNo moriré por tan poco.
Dialogue: 0,0:11:33.81,0:11:35.93,Default,Anna,0,0,0,,Quiero quedarme\Nal lado del príncipe.
Dialogue: 0,0:11:44.02,0:11:45.02,Default,Rossignol,0,0,0,,Está bien.
Dialogue: 0,0:11:45.52,0:11:48.35,Default,Rossignol,0,0,0,,En ese caso,\Nyo me quedo en Frontera también.
Dialogue: 0,0:11:48.93,0:11:53.43,Default,Rossignol,0,0,0,,Estabas dispuesto a recibir\Na toda nuestra comunidad.
Dialogue: 0,0:11:54.72,0:11:58.81,Default,Rossignol,0,0,0,,Tengo la experiencia\Npara ayudarla a pasar esta prueba.
Dialogue: 0,0:11:59.56,0:12:03.77,Default,Rossignol,0,0,0,,Y si sucumbes,\Nme haré cargo de las consecuencias.
Dialogue: 0,0:12:04.14,0:12:06.64,Default,Anna,0,0,0,,No pasará.\NSobreviviré, lo juro.
Dialogue: 0,0:12:10.89,0:12:13.81,Default,Rossignol,0,0,0,,Gracias por recibirme\Ny perdón por las molestias.
Dialogue: 0,0:12:14.31,0:12:15.22,Default,Roland,0,0,0,,De nada.
Dialogue: 0,0:12:28.39,0:12:31.39,Default,Roland,0,0,0,,Los dejo descansar.
Dialogue: 0,0:12:36.39,0:12:38.35,Default,Anna,0,0,0,,Gracias, Alteza.
Dialogue: 0,0:13:16.14,0:13:17.43,Default,Carter,0,0,0,,Buenos días, Alteza.
Dialogue: 0,0:13:18.35,0:13:20.77,Default,Roland,0,0,0,,Buenos días, Carter.
Dialogue: 0,0:13:21.22,0:13:22.39,Default,Roland,0,0,0,,¿Qué pasa?
Dialogue: 0,0:13:22.64,0:13:24.72,Default,Carter,0,0,0,,Su sirvienta, Tyre, ha muerto.
Dialogue: 0,0:13:24.85,0:13:26.77,Default,Roland,0,0,0,,¿Qué? ¿Qué pasó?
Dialogue: 0,0:13:27.02,0:13:30.22,Default,Carter,0,0,0,,Esta mañana, un guardia la encontró\Ntirada bajo su balcón.
Dialogue: 0,0:13:30.35,0:13:32.85,Default,Carter,0,0,0,,No había señales de lucha.
Dialogue: 0,0:13:32.97,0:13:36.10,Default,Carter,0,0,0,,Debe ser un accidente.
Dialogue: 0,0:13:37.39,0:13:38.35,Default,Roland,0,0,0,,Dale…
Dialogue: 0,0:13:39.72,0:13:40.77,Default,Roland,0,0,0,,un buen funeral.
Dialogue: 0,0:13:40.85,0:13:42.06,Default,Carter,0,0,0,,Claro, Alteza.
Dialogue: 0,0:13:42.31,0:13:46.14,Default,Roland,0,0,0,,Te alcanzo en la reunión\Ndespués del desayuno.
Dialogue: 0,0:13:46.27,0:13:47.43,Default,Carter,0,0,0,,Perfecto.
Dialogue: 0,0:13:51.81,0:13:53.35,Default,Rossignol,0,0,0,,Buenos días, Alteza.
Dialogue: 0,0:14:07.68,0:14:08.77,Default,Roland,0,0,0,,¿Fuiste tú?
Dialogue: 0,0:14:08.93,0:14:11.18,Default,Rossignol,0,0,0,,Como me hospedas,
Dialogue: 0,0:14:11.31,0:14:13.18,Default,Roland,0,0,0,,quise hacer un poco de limpieza.
Dialogue: 0,0:14:13.31,0:14:15.06,Default,Roland,0,0,0,,¿Sabes quién la mandó?
Dialogue: 0,0:14:18.10,0:14:20.27,Default,Rossignol,0,0,0,,La verdad, no la maté.
Dialogue: 0,0:14:20.39,0:14:23.31,Default,Roland,0,0,0,,Se envenenó\Ncuando me vio.
Dialogue: 0,0:14:23.64,0:14:25.39,Default,Roland,0,0,0,,Disfrazé su muerte como accidente.
Dialogue: 0,0:14:25.52,0:14:29.22,Default,Roland,0,0,0,,Alguien raptó a su hermana\Npara chantajearla.
Dialogue: 0,0:14:30.31,0:14:32.39,Default,Roland,0,0,0,,Seguro\None de mis hermanos…
Dialogue: 0,0:14:35.52,0:14:38.56,Default,Rossignol,0,0,0,,Los nobles siempre han sido retorcidos.
Dialogue: 0,0:14:39.85,0:14:43.31,Default,Roland,0,0,0,,Bueno, lo esperan para la reunión.\NDeberías ir.
Dialogue: 0,0:14:45.14,0:14:47.97,Default,Roland,0,0,0,,Pero aún no he…
Dialogue: 0,0:15:00.97,0:15:03.22,Default,Barov,0,0,0,,¿Todo bien, mi príncipe?
Dialogue: 0,0:15:03.35,0:15:06.27,Default,Barov,0,0,0,,Pareces exhausto\Nestos últimos días.
Dialogue: 0,0:15:06.47,0:15:08.81,Default,Roland,0,0,0,,No es nada,\Nsolo tengo hambre.
Dialogue: 0,0:15:08.93,0:15:10.85,Default,Carter,0,0,0,,Pero si acaba de…
Dialogue: 0,0:15:10.97,0:15:13.64,Default,Roland,0,0,0,,En fin, empecemos.
Dialogue: 0,0:15:13.72,0:15:14.72,Default,Barov,0,0,0,,Perfecto.
Dialogue: 0,0:15:15.43,0:15:19.97,Default,Barov,0,0,0,,Las ventas de mineral a mitad de precio\Na Saule solo trajeron
Dialogue: 0,0:15:20.10,0:15:21.97,Default,Barov,0,0,0,,200 dragones de oro.
Dialogue: 0,0:15:22.10,0:15:25.18,Default,Barov,0,0,0,,Tras descontar el costo de víveres\Ny del muro,
Dialogue: 0,0:15:25.27,0:15:26.93,Default,Barov,0,0,0,,nos quedan solo 90.
Dialogue: 0,0:15:27.02,0:15:30.02,Default,Barov,0,0,0,,No es ideal,\Npero pasaremos el invierno.
Dialogue: 0,0:15:30.14,0:15:32.89,Default,Barov,0,0,0,,Sin embargo, para pagar\\Aa nuestros futuros soldados,
Dialogue: 0,0:15:33.02,0:15:36.47,Default,Barov,0,0,0,,tendremos que sacar\Nde tus arcas personales.
Dialogue: 0,0:15:36.60,0:15:38.06,Default,Roland,0,0,0,,Bien. Carter,
Dialogue: 0,0:15:38.35,0:15:39.81,Default,Roland,0,0,0,,¿cómo va el reclutamiento?
Dialogue: 0,0:15:39.93,0:15:42.43,Default,Carter,0,0,0,,Bueno… Tenemos\Nmucha gente interesada.
Dialogue: 0,0:15:42.56,0:15:45.22,Default,Carter,0,0,0,,Pronto llegaremos\Na las cien cabezas.
Dialogue: 0,0:15:45.35,0:15:48.93,Default,Carter,0,0,0,,Pero entrenarlos será\Notro par de mangas.
Dialogue: 0,0:15:49.06,0:15:52.31,Default,Carter,0,0,0,,Son campesinos,\Nno guerreros.
Dialogue: 0,0:15:52.43,0:15:53.93,Default,Carter,0,0,0,,No tienen experiencia.
Dialogue: 0,0:15:54.06,0:15:56.68,TiretsDefault,Roland/Carter,191,0,0,,– ¿Qué propones?\N– Necesitamos caballeros.
Dialogue: 0,0:15:56.81,0:15:59.43,Default,Carter,0,0,0,,No te gustan\Nlos nobles de la zona,
Dialogue: 0,0:15:59.56,0:16:03.85,Default,Carter,0,0,0,,pero necesitaremos el apoyo\Ndel barón Boris y sus caballeros.
Dialogue: 0,0:16:04.02,0:16:08.27,Default,Carter,0,0,0,,Déjame ir a verlo.\N¡Va la seguridad de Frontera!
Dialogue: 0,0:16:08.47,0:16:11.52,Default,Carter,0,0,0,,Debemos intentar\Nque se una a nuestra causa.
Dialogue: 0,0:16:14.35,0:16:15.81,Default,Roland,0,0,0,,Entendido.
Dialogue: 0,0:16:16.39,0:16:20.27,Default,Roland,0,0,0,,Avisa al barón\Nque lo visito mañana por la mañana.
Dialogue: 0,0:16:21.02,0:16:22.10,Default,Carter,0,0,0,,A sus órdenes.
Dialogue: 0,0:16:23.10,0:16:24.14,Default,Carter,0,0,0,,Mil gracias.
Dialogue: 0,0:16:34.97,0:16:39.47,Default,Barov,0,0,0,,Alteza, ¿crees\Nque el barón nos ayudará?
Dialogue: 0,0:16:40.02,0:16:41.35,Default,Roland,0,0,0,,Poco probable.
Dialogue: 0,0:16:41.47,0:16:43.47,Default,Roland,0,0,0,,Pero Carter tiene buenas intenciones,
Dialogue: 0,0:16:43.93,0:16:46.72,Default,Roland,0,0,0,,no quería decepcionarlo.
Dialogue: 0,0:16:47.56,0:16:50.43,Default,Barov,0,0,0,,No tiene madera política.
Dialogue: 0,0:16:50.56,0:16:53.47,Default,Barov,0,0,0,,Pero estratégicamente,\Ntiene razón.
Dialogue: 0,0:16:53.81,0:16:56.85,Default,Barov,0,0,0,,Alteza, tu reina ha caído.
Dialogue: 0,0:16:56.97,0:17:00.68,Default,Barov,0,0,0,,Tus caballeros están rodeados,\Nestás acorralado.
Dialogue: 0,0:17:00.85,0:17:03.56,Default,Barov,0,0,0,,Hasta perdiste tus torres.
Dialogue: 0,0:17:03.72,0:17:06.18,Default,Barov,0,0,0,,Tu derrota es obvia.
Dialogue: 0,0:17:07.68,0:17:09.31,Default,Roland,0,0,0,,Te ciega,
Dialogue: 0,0:17:09.81,0:17:10.77,Default,Roland,0,0,0,,Barov.
Dialogue: 0,0:17:11.39,0:17:13.43,Default,Roland,0,0,0,,Los que me darán\Nla victoria,
Dialogue: 0,0:17:14.85,0:17:18.31,Default,Roland,0,0,0,,serán todos los peones\Nque estén dispuestos a pelear
Dialogue: 0,0:17:18.64,0:17:20.22,Default,Roland,0,0,0,,hasta el final.
Dialogue: 0,0:17:20.35,0:17:24.18,Default,Barov,0,0,0,,Aunque tengas el apoyo\Nde tus súbditos,
Dialogue: 0,0:17:24.31,0:17:28.22,Default,Barov,0,0,0,,no tienen experiencia\Nen combate.
Dialogue: 0,0:17:29.31,0:17:31.35,Default,Roland,0,0,0,,Lo arreglaremos pronto.
Dialogue: 0,0:17:31.97,0:17:32.93,Default,Roland,0,0,0,,Además,
Dialogue: 0,0:17:34.06,0:17:36.64,Default,Roland,0,0,0,,no irán a pelear\Ncon las manos vacías.
Dialogue: 0,0:17:40.18,0:17:42.47,Default,Roland,0,0,0,,Así, y luego, como esto.
Dialogue: 0,0:17:42.60,0:17:44.39,Default,Roland,0,0,0,,¿Ven ese hueco?
Dialogue: 0,0:17:44.52,0:17:45.43,Default,Anna,0,0,0,,Sí.
Dialogue: 0,0:17:45.52,0:17:48.93,Default,Roland,0,0,0,,Concentra tus llamas en un punto,\Nlo más pequeño posible.
Dialogue: 0,0:17:49.60,0:17:52.68,Default,Roland,0,0,0,,Quémalo suavemente\Npor toda la línea.
Dialogue: 0,0:18:00.89,0:18:05.18,Default,Roland,0,0,0,,Sé más precisa.\NConcentra el calor en tus dedos.
Dialogue: 0,0:18:06.31,0:18:08.52,Default,Roland,0,0,0,,Otra vez, concéntralo más.
Dialogue: 0,0:18:09.35,0:18:10.52,Default,Roland,0,0,0,,Así, perfecto.
Dialogue: 0,0:18:11.22,0:18:12.10,Default,Roland,0,0,0,,Suave.
Dialogue: 0,0:18:14.56,0:18:17.31,Default,Roland,0,0,0,,Sigue la línea.\NMuy bien, hasta el final.
Dialogue: 0,0:18:17.89,0:18:20.81,Default,Roland,0,0,0,,Todo suave, sin temblar.
Dialogue: 0,0:18:23.31,0:18:24.18,Default,Roland,0,0,0,,¡Bien hecho!
Dialogue: 0,0:18:30.68,0:18:31.56,Default,Roland,0,0,0,,Anna.
Dialogue: 0,0:18:32.14,0:18:33.14,Default,Anna,0,0,0,,Alteza.
Dialogue: 0,0:18:36.97,0:18:38.39,Default,Roland,0,0,0,,Mira.
Dialogue: 0,0:18:39.18,0:18:41.14,Default,Roland,0,0,0,,Admira nuestro trabajo.
Dialogue: 0,0:18:41.89,0:18:45.22,TiretsDefault,Roland/Anna,198,0,0,,– Lo lograste.\N– ¿Qué hemos hecho?
Dialogue: 0,0:18:46.85,0:18:48.39,Default,Roland,0,0,0,,Lo sabrás pronto.
Dialogue: 0,0:18:49.06,0:18:50.22,Default,Roland,0,0,0,,Nuestra creación
Dialogue: 0,0:18:50.77,0:18:52.93,Default,Roland,0,0,0,,inaugurará una nueva era.
Dialogue: 0,0:19:04.60,0:19:06.39,Default,Rossignol,0,0,0,,Buenas noches, Alteza.
Dialogue: 0,0:19:07.43,0:19:09.52,Default,Roland,0,0,0,,Siempre entras de sigilo.
Dialogue: 0,0:19:10.89,0:19:12.77,Default,Rossignol,0,0,0,,Qué comentario tan raro.
Dialogue: 0,0:19:12.89,0:19:16.56,Default,Roland,0,0,0,,Protejo tu seguridad,\Na Anna y a ti,
Dialogue: 0,0:19:16.85,0:19:18.52,Default,Roland,0,0,0,,contra otros asesinos.
Dialogue: 0,0:19:19.43,0:19:20.85,Default,Roland,0,0,0,,Ah, bueno, gracias.
Dialogue: 0,0:19:21.60,0:19:25.27,Default,Rossignol,0,0,0,,No hace falta agradecerme,\Nme conviene.
Dialogue: 0,0:19:26.56,0:19:29.47,Default,Roland,0,0,0,,¿Esto es lo que fabrican\Ncon Anna?
Dialogue: 0,0:19:30.14,0:19:31.77,Default,Roland,0,0,0,,¡Estaban en mi oficina!
Dialogue: 0,0:19:33.22,0:19:35.52,Default,Rossignol,0,0,0,,Pensé\Nque podría ser útil.
Dialogue: 0,0:19:35.89,0:19:38.56,Default,Roland,0,0,0,,Otras brujas pueden\Nmanipular el fuego.
Dialogue: 0,0:19:39.35,0:19:41.35,Default,Roland,0,0,0,,Llévatelas, haré otros planos.
Dialogue: 0,0:19:42.27,0:19:44.02,Default,Rossignol,0,0,0,,Eres bueno con Anna.
Dialogue: 0,0:19:44.27,0:19:45.68,Default,Roland,0,0,0,,Ella confía en ti.
Dialogue: 0,0:19:47.18,0:19:48.89,Default,Roland,0,0,0,,Yo ya no recuerdo
Dialogue: 0,0:19:49.39,0:19:51.60,Default,Roland,0,0,0,,qué se siente\Nconfiar.
Dialogue: 0,0:20:02.93,0:20:07.27,Default,Carter,0,0,0,,La mansión del barón Boris\Nestá al oeste de Frontera.
Dialogue: 0,0:20:07.52,0:20:10.93,Default,Carter,0,0,0,,Se distingue de las otras casas.
Dialogue: 0,0:20:12.47,0:20:14.52,Default,Carter,0,0,0,,El barón contrató\Na un arquitecto
Dialogue: 0,0:20:14.64,0:20:16.85,Default,Carter,0,0,0,,y usó los mejores materiales.
Dialogue: 0,0:20:17.27,0:20:19.39,Default,Carter,0,0,0,,Es un edificio\Ndigno de la capital.
Dialogue: 0,0:20:20.14,0:20:24.35,Default,Carter,0,0,0,,Le encanta gritar a los cuatro vientos\Nque su mansión costó 150 dragones de oro.
Dialogue: 0,0:20:25.85,0:20:27.81,Default,Roland,0,0,0,,Muero por verlo.
Dialogue: 0,0:20:48.52,0:20:53.22,Default,Boris,0,0,0,,Admiro tu determinación\Npor proteger Frontera.
Dialogue: 0,0:20:53.35,0:20:56.68,Default,Boris,0,0,0,,Me honra que pensaras\Nen mí para ayudarte.
Dialogue: 0,0:20:56.93,0:21:00.35,Default,Boris,0,0,0,,Pero no entendí bien\Nqué esperas de nosotros.
Dialogue: 0,0:21:00.72,0:21:03.43,Default,Roland,0,0,0,,A mi guardia le faltan\Narmas e instructores
Dialogue: 0,0:21:03.56,0:21:07.64,Default,Roland,0,0,0,,con experiencia en combate.\NAsí que esperaba
Dialogue: 0,0:21:07.85,0:21:10.85,Default,Roland,0,0,0,,que tus caballeros protegieran\NFrontera.
Dialogue: 0,0:21:11.18,0:21:13.10,Default,Boris,0,0,0,,Lo entiendo mejor.
Dialogue: 0,0:21:13.22,0:21:16.39,Default,Boris,0,0,0,,Como te tomaste la molestia\Nde venir en persona,
Dialogue: 0,0:21:16.52,0:21:18.72,Default,Boris,0,0,0,,es nuestro deber\Nayudarte.
Dialogue: 0,0:21:18.85,0:21:22.10,Default,Boris,0,0,0,,Lástima que cae mal.
Dialogue: 0,0:21:25.72,0:21:27.60,Default,Boris,0,0,0,,Mis caballeros acaban de volver
Dialogue: 0,0:21:27.77,0:21:30.85,Default,Boris,0,0,0,,de una cacería\Ny están exhaustos.
Dialogue: 0,0:21:30.97,0:21:34.14,Default,Boris,0,0,0,,Además, las bestias demoníacas\Nson peligrosas.
Dialogue: 0,0:21:34.27,0:21:36.81,Default,Boris,0,0,0,,Me niego a mandar a mis hombres\Nal matadero.
Dialogue: 0,0:21:37.31,0:21:41.18,Default,Boris,0,0,0,,Debes necesitar fondos\Npara levantar tu ejército.
Dialogue: 0,0:21:41.31,0:21:44.35,Default,Boris,0,0,0,,Así que, para mostrarte\Nnuestro apoyo,
Dialogue: 0,0:21:44.47,0:21:45.68,Default,Boris,0,0,0,,varias familias
Dialogue: 0,0:21:45.81,0:21:50.60,Default,Boris,0,0,0,,decidieron apoyarte\Nfinancieramente
Dialogue: 0,0:21:50.77,0:21:53.35,Default,Boris,0,0,0,,con una donación.
Dialogue: 0,0:21:53.47,0:21:55.77,TiretsDefault,Boris/Carter,222,0,0,,– Acéptala, por favor.\N– ¿Un solo dragón?
Dialogue: 0,0:21:56.68,0:21:57.77,Default,Carter,0,0,0,,¡Qué insulto!
Dialogue: 0,0:21:57.89,0:21:58.81,Default,Roland,0,0,0,,Carter.
Dialogue: 0,0:22:01.31,0:22:03.35,Default,Roland,0,0,0,,Gracias por la donación.
Dialogue: 0,0:22:03.52,0:22:04.39,Default,Carter,0,0,0,,¡Alteza!
Dialogue: 0,0:22:04.52,0:22:07.31,Default,Roland,0,0,0,,Me retiro entonces.
Dialogue: 0,0:22:08.10,0:22:11.35,Default,Boris,0,0,0,,Me duelen las piernas,\Nno te acompaño.
Dialogue: 0,0:22:21.64,0:22:23.56,Default,Carter,0,0,0,,Lo siento muchísimo.
Dialogue: 0,0:22:24.02,0:22:25.93,Default,Carter,0,0,0,,Te humillaron\Npor mi culpa.
Dialogue: 0,0:22:26.60,0:22:31.27,Default,Carter,0,0,0,,Sabía que se negarían\Na ayudarnos, pero esto…
Dialogue: 0,0:22:31.60,0:22:34.77,Default,Carter,0,0,0,,Es un insulto a la caballería.
Dialogue: 0,0:22:35.77,0:22:38.77,Default,Roland,0,0,0,,No te tortures,\Nme lo esperaba.
Dialogue: 0,0:22:39.14,0:22:42.22,Default,Roland,0,0,0,,Al menos tengo para pagar\Nel sueldo de Karl.
Dialogue: 0,0:22:42.47,0:22:44.27,Default,Roland,0,0,0,,Y así estamos claros.
Dialogue: 0,0:22:44.47,0:22:48.18,Default,Roland,0,0,0,,No podemos contar\Ncon la aristocracia.
Dialogue: 0,0:22:49.31,0:22:52.81,Default,Carter,0,0,0,,Pero… sin ella y sus caballeros,\N¿cómo entrenaremos
Dialogue: 0,0:22:53.02,0:22:54.81,Default,Carter,0,0,0,,a nuestras tropas?
Dialogue: 0,0:23:01.89,0:23:03.39,Default,Roland,0,0,0,,Tengo mi idea.
